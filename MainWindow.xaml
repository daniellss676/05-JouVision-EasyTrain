<Window x:Class="JouVisionEasyTrain.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JouVision EasyTrain - 视频拆分"
        Height="620"
        Width="1060"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="视频拆分"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock Text="选择视频和目标帧率，将视频按固定 FPS 导出为训练图片。"
                       Margin="0,8,0,0"
                       Foreground="#64748B" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="视频文件"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="VideoPathTextBox"
                             Grid.Column="1"
                             IsReadOnly="True" />
                    <Button x:Name="SelectVideoButton"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Content="选择视频"
                            Click="SelectVideoButton_Click" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="输出文件夹"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="OutputFolderTextBox"
                             Grid.Column="1"
                             IsReadOnly="True" />
                    <Button x:Name="SelectOutputButton"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Content="选择文件夹"
                            Click="SelectOutputButton_Click" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="原始帧率"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SourceFrameRateTextBlock"
                               Grid.Column="1"
                               Text="未读取"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="目标帧率"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="FrameRateTextBox"
                             Grid.Column="1"
                             Text="1" />
                    <TextBlock Grid.Column="2"
                               Text="FPS"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />

                    <TextBlock Grid.Column="3"
                               Text="图片格式"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <ComboBox x:Name="ImageFormatComboBox"
                              Grid.Column="4"
                              SelectedIndex="0">
                        <ComboBoxItem Content="jpg" />
                        <ComboBoxItem Content="png" />
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="处理进度"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <ProgressBar x:Name="ProgressBar"
                                 Grid.Column="1"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100" />
                    <TextBlock x:Name="ProgressTextBlock"
                               Grid.Column="2"
                               Text="0%"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </Grid>

                <Border Grid.Row="5"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="等待选择视频。"
                               TextWrapping="Wrap"
                               Foreground="#475569" />
                </Border>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center">
                <TextBlock x:Name="SummaryTextBlock"
                           Foreground="#64748B"
                           Text="输出文件名格式：视频名_000001.jpg" />
                <TextBlock Text="Author: Daniellss"
                           Margin="0,4,0,0"
                           Foreground="#94A3B8"
                           FontSize="12" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="OpenOutputButton"
                        Content="打开输出文件夹"
                        IsEnabled="False"
                        Click="OpenOutputButton_Click" />
                <Button x:Name="CancelButton"
                        Margin="12,0,0,0"
                        Content="取消"
                        IsEnabled="False"
                        Click="CancelButton_Click" />
                <Button x:Name="StartButton"
                        Margin="12,0,0,0"
                        Content="开始生成"
                        Background="#2563EB"
                        BorderBrush="#2563EB"
                        Foreground="White"
                        Click="StartButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
