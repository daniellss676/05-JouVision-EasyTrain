<Window x:Class="JouVisionEasyTrain.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JouVision EasyTrain - 视频拆分"
        Height="1100"
        Width="1000"
        MinHeight="680"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Icon="LOGO.png"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PlayerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,22" Orientation="Horizontal">
            <Image Source="LOGO.png"
                   Width="64"
                   Height="64"
                   Stretch="Uniform"
                   Margin="0,0,18,0" />
            <StackPanel VerticalAlignment="Center">
            <TextBlock Text="视频拆分"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock Text="选择视频和目标帧率，将视频按固定 FPS 导出为训练图片。"
                       Margin="0,8,0,0"
                       Foreground="#64748B" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="230" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="视频文件"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="VideoPathTextBox"
                             Grid.Column="1"
                             IsReadOnly="True" />
                    <Button x:Name="SelectVideoButton"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Padding="0"
                            Content="选择视频"
                            Click="SelectVideoButton_Click" />
                </Grid>

                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="输出文件夹"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="OutputFolderTextBox"
                             Grid.Column="1"
                             IsReadOnly="True" />
                    <Button x:Name="SelectOutputButton"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Padding="0"
                            Content="选择文件夹"
                            Click="SelectOutputButton_Click" />
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="原始帧率"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SourceFrameRateTextBlock"
                               Grid.Column="1"
                               Text="未读取"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </Grid>

                <Grid Grid.Row="3" Grid.Column="0" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="目标帧率"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="FrameRateTextBox"
                             Grid.Column="1"
                             Text="1" />
                    <TextBlock Grid.Column="2"
                               Text="FPS"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />

                    <TextBlock Grid.Column="3"
                               Text="图片格式"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <ComboBox x:Name="ImageFormatComboBox"
                              Grid.Column="4"
                              SelectedIndex="0">
                        <ComboBoxItem Content="jpg" />
                        <ComboBoxItem Content="png" />
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="4" Grid.Column="0" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="处理进度"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <ProgressBar x:Name="ProgressBar"
                                 Grid.Column="1"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100" />
                    <TextBlock x:Name="ProgressTextBlock"
                               Grid.Column="2"
                               Text="0%"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </Grid>

                <Border Grid.Row="5"
                        Grid.Column="0"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="等待选择视频。"
                               TextWrapping="Wrap"
                               Foreground="#475569" />
                </Border>

                <Border Grid.Row="6"
                        Grid.Column="0"
                        Margin="0,18,0,0"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="VideoPreviewImage"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       SnapsToDevicePixels="True">
                                    <Image.LayoutTransform>
                                        <RotateTransform x:Name="VideoPreviewRotateTransform" Angle="0" />
                                    </Image.LayoutTransform>
                                </Image>
                                <TextBlock x:Name="PlayerPlaceholderTextBlock"
                                           Text="选择视频后可在这里预览播放"
                                           Foreground="#64748B"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="18" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,12,0,8">
                            <Slider x:Name="VideoPositionSlider"
                                    Minimum="0"
                                    Maximum="1"
                                    IsEnabled="False"
                                    PreviewMouseDown="VideoPositionSlider_PreviewMouseDown"
                                    PreviewMouseUp="VideoPositionSlider_PreviewMouseUp"
                                    ValueChanged="VideoPositionSlider_ValueChanged"
                                    SizeChanged="VideoPositionSlider_SizeChanged" />
                            <Canvas x:Name="SegmentMarkerCanvas"
                                    IsHitTestVisible="False"
                                    Margin="8,0"
                                    ClipToBounds="False">
                                <Ellipse x:Name="SegmentStartMarkerDot"
                                         Visibility="Collapsed"
                                         Width="10"
                                         Height="10"
                                         Fill="#EF4444" />
                                <Ellipse x:Name="SegmentEndMarkerDot"
                                         Visibility="Collapsed"
                                         Width="10"
                                         Height="10"
                                         Fill="#EF4444" />
                            </Canvas>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RotatePreviewButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PlayerButtonStyle}"
                                    Content="&#x27F3;"
                                    IsEnabled="False"
                                    Click="RotatePreviewButton_Click" />
                            <Button x:Name="PlayPauseButton"
                                    Grid.Column="1"
                                    Style="{StaticResource PlayerButtonStyle}"
                                    Content="播放"
                                    IsEnabled="False"
                                    Click="PlayPauseButton_Click" />
                            <Button x:Name="StopPlaybackButton"
                                    Visibility="Collapsed"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource PlayerButtonStyle}"
                                    Content="停止"
                                    IsEnabled="False"
                                    Click="StopPlaybackButton_Click" />
                            <TextBlock x:Name="VideoTimeTextBlock"
                                       Grid.Column="2"
                                       Text="00:00 / 00:00"
                                       Foreground="#475569"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="SetSegmentStartButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Content="设置为起点"
                                    IsEnabled="False"
                                    Click="SetSegmentStartButton_Click" />
                            <Button x:Name="SetSegmentEndButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Content="设置为终点"
                                    IsEnabled="False"
                                    Click="SetSegmentEndButton_Click" />
                            <TextBlock x:Name="SegmentRangeTextBlock"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Text="导出范围：完整视频"
                                       Foreground="#475569"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <StackPanel DockPanel.Dock="Left"
                        VerticalAlignment="Center">
                <TextBlock x:Name="SummaryTextBlock"
                           Foreground="#64748B"
                           Text="输出文件名格式：视频名_000001.jpg" />
                <TextBlock Text="Author: Daniellss"
                           Margin="0,4,0,0"
                           Foreground="#94A3B8"
                           FontSize="12" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="OpenOutputButton"
                        Content="打开输出文件夹"
                        IsEnabled="False"
                        Click="OpenOutputButton_Click" />
                <Button x:Name="CancelButton"
                        Margin="12,0,0,0"
                        Content="取消"
                        IsEnabled="False"
                        Click="CancelButton_Click" />
                <Button x:Name="StartButton"
                        Margin="12,0,0,0"
                        Content="开始生成"
                        Background="#2563EB"
                        BorderBrush="#2563EB"
                        Foreground="White"
                        Click="StartButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
